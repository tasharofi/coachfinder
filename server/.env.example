# ============================
# Server environment variables
# Copy this file to .env and fill in values
# ============================

# PostgreSQL — provided by Railway automatically
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT — use a long random string (e.g. run: openssl rand -hex 32)
JWT_SECRET="your-secret-here"

# Frontend URL — set to your Vercel deployment URL (no trailing slash)
FRONTEND_URL="https://your-app.vercel.app"

# Cloudinary — from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Optional: Google OAuth
GOOGLE_CLIENT_ID=""

# Optional: AI features (Groq or Gemini)
GROQ_API_KEY=""
GEMINI_API_KEY=""

# Optional: Email (nodemailer)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
